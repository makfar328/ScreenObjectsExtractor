<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>

<?import javafx.scene.control.ScrollPane?>
<AnchorPane fx:id="anchorPane_layer1"
            prefHeight="400.0" prefWidth="600.0"
            stylesheets="@../css/style-screen-analysis-results.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.makar.ocrapp.screenobjectsextractor.view.screenalalysisresults.ScreenAnalysisResultsController">
    <VBox AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
        <MenuBar fx:id="menuBar">
            <menus>
                <Menu fx:id="fileMenu" text="File">
                    <items>
                        <MenuItem fx:id="closeMenuItem" text="Close"/>
                    </items>
                </Menu>
                <Menu fx:id="helpMenu" text="Help">
                    <items>
                        <MenuItem fx:id="aboutMenuItem" text="About"/>
                    </items>
                </Menu>
            </menus>
        </MenuBar>
        <SplitPane fx:id="splitPane_layer3_prevVBox" dividerPositions="0.66" VBox.vgrow="ALWAYS">
            <!-- Left part (2/3 width) - for image -->
            <AnchorPane fx:id="leftImageContainer" style="-fx-background-color: #2B2B2B;" minWidth="0.0" minHeight="0.0">
                <AnchorPane fx:id="imageDisplayAnchorPane" minWidth="200.0" minHeight="100.0" AnchorPane.bottomAnchor="3.0" AnchorPane.leftAnchor="3.0" AnchorPane.rightAnchor="3.0" AnchorPane.topAnchor="3.0"
                            style="-fx-background-color: #1E1F22; -fx-background-radius: 20;">
                    <Rectangle fx:id="capturedImageBorder" arcHeight="20" arcWidth="20" fill="TRANSPARENT" stroke="#555555" strokeWidth="2"/>
                    <HBox fx:id="HBoxForCenteringImageView" alignment="CENTER">
                        <ImageView fx:id="capturedImageView" preserveRatio="true"/>
                        <Rectangle fx:id="highlightRectangle"
                                   fill="transparent"
                                   stroke="LIGHTBLUE"
                                   strokeWidth="2"
                                   arcHeight="10"
                                   arcWidth="10"
                                   managed="false"
                                   visible="false" />
                    </HBox>
                </AnchorPane>
            </AnchorPane>

            <!-- Right part (1/3 width) - for controls -->
            <AnchorPane fx:id="rightControlContainer" style="-fx-background-color: #313335;">
                <ScrollPane fx:id="scrollVBoxElements">

                    <VBox AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="10.0"
                          AnchorPane.bottomAnchor="10.0">
                        <HBox fx:id="buttonHBox" alignment="CENTER">
                            <Region fx:id="leftButtonSpacer" HBox.hgrow="ALWAYS"/>
                            <Button fx:id="recognizedTextButton" styleClass="validation-button-left" text="Текст"/>
                            <Button fx:id="detectedObjectsButton" styleClass="validation-button-middle" text="Объекты"/>
                            <Button fx:id="qrButton" styleClass="validation-button-middle" text="QR" visible="false" managed="false"/>
                            <Button fx:id="tablesButton" styleClass="validation-button-right" text="Таблицы" visible="false" managed="false"/>

                            <Region fx:id="rightButtonSpacer" HBox.hgrow="ALWAYS"/>
                        </HBox>
                        <!-- Контейнер для списка объектов -->
                        <VBox fx:id="objectListVBox" VBox.vgrow="ALWAYS" style="-fx-padding: 10;"/>
                    </VBox>
                </ScrollPane>

            </AnchorPane>
        </SplitPane>
    </VBox>
</AnchorPane>