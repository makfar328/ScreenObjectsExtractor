<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>

<!-- Корневой элемент BorderPane с указанием контроллера и начальными стилями -->
<BorderPane xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.makar.ocrapp.screenobjectsextractor.view.texteditor.TextEditorController"
            prefWidth="300" prefHeight="500"
            style="-fx-background-color: white; -fx-background-radius: 15; -fx-border-radius: 15; -fx-border-color: #ddd; -fx-border-width: 1;">
    <padding>
        <!-- Общие отступы для всего содержимого BorderPane -->
        <Insets top="10" right="10" bottom="10" left="10"/>
    </padding>
    <center>
        <!-- Текстовая область для редактирования -->
        <TextArea fx:id="textArea" promptText="Введите текст для редактирования..."
                  wrapText="true"
                  style="-fx-control-inner-background:#ffffff; -fx-font-size: 14px; -fx-border-color: #ccc; -fx-border-width: 1; -fx-border-radius: 5;"/>
    </center>
    <bottom>
        <!-- HBox для кнопок "Сохранить" и "Закрыть", выровненный по правому краю -->
        <HBox alignment="CENTER_RIGHT" spacing="10">
            <!-- Кнопка "Сохранить" со стилями -->
            <Button fx:id="saveButton" text="Сохранить" onAction="#handleSaveButtonAction"
                    style="-fx-background-color: #007bff; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 8 15; -fx-background-radius: 5;"/>
            <!-- Кнопка "Закрыть" со стилями -->
            <Button fx:id="closeButton" text="Закрыть" onAction="#handleCloseButtonAction"
                    style="-fx-background-color: #6c757d; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 8 15; -fx-background-radius: 5;"/>
        </HBox>
    </bottom>
</BorderPane>