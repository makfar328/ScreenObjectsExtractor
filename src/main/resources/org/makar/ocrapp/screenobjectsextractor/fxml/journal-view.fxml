<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            stylesheets="@../css/style-journal.css"
            fx:controller="org.makar.ocrapp.screenobjectsextractor.view.journal.JournalController"
            prefHeight="500.0" prefWidth="700.0" id="background-pane">

    <VBox spacing="0"
          AnchorPane.rightAnchor="0"
          AnchorPane.leftAnchor="0"
          AnchorPane.topAnchor="0"
          AnchorPane.bottomAnchor="0">

        <HBox styleClass="tab-bar">
            <Button fx:id="searchSessionsTabButton"
                    styleClass="tab-btn"
                    text="Сессии поиска"/>
            <Button fx:id="decomposeSessionsTabButton"
                    styleClass="tab-btn"
                    text="Сессии декомпозиции"/>
            <Button fx:id="systemLogsTabButton"
                    styleClass="tab-btn"
                    text="Системные логи"/>
        </HBox>

        <StackPane fx:id="journalContentPane"
                   id="journal-content-pane"
                   VBox.vgrow="ALWAYS"/>
    </VBox>
</AnchorPane>